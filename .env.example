# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit it.
# Retrieve values by running: npx supabase projects api-keys --project-ref <your-project-ref>

# ── Browser / Vite ────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=               # https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=          # anon / public key — safe for browser use
VITE_SUPABASE_PUBLISHABLE_KEY=   # alias for VITE_SUPABASE_ANON_KEY (Lovable naming)

# ── Server / scripts only — NEVER expose to the browser ─────────────────────
SUPABASE_URL=                    # same as VITE_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=       # service_role key — bypasses RLS, server use only
