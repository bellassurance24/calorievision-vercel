# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit it.
# Retrieve values by running: npx supabase projects api-keys --project-ref <your-project-ref>

# ── Browser / Vite ────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=               # https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=          # anon / public key — safe for browser use
VITE_SUPABASE_PUBLISHABLE_KEY=   # alias for VITE_SUPABASE_ANON_KEY (Lovable naming)

# ── Server / scripts only — NEVER expose to the browser ─────────────────────
SUPABASE_URL=                    # same as VITE_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=       # service_role key — bypasses RLS, server use only

# ── Stripe price IDs (NOT secrets — public catalog identifiers) ───────────────
# Find these in Stripe Dashboard → Products → click the product → copy "Price ID"
# Add these EXACT variable names to Vercel: Settings → Environment Variables
VITE_STRIPE_PRICE_PRO_MONTHLY=       # price_1...  (Pro plan, billed monthly)
VITE_STRIPE_PRICE_PRO_YEARLY=        # price_1...  (Pro plan, billed yearly)
VITE_STRIPE_PRICE_ULTIMATE_MONTHLY=  # price_1...  (Ultimate plan, billed monthly)
VITE_STRIPE_PRICE_ULTIMATE_YEARLY=   # price_1...  (Ultimate plan, billed yearly)
